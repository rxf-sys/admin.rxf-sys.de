# Caddy config used inside the frontend container.
# Serves the built SPA and proxies /api/* to the backend service.

:80 {
	encode zstd gzip

	# API → backend service (docker-compose service name)
	reverse_proxy /api/* backend:8080 {
		header_up X-Forwarded-Proto {scheme}
	}

	# Static assets with long cache
	@assets {
		path /assets/*
	}
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# SPA fallback — always serve index.html for unknown routes
	root * /srv
	try_files {path} /index.html
	file_server

	# Don't index this admin tool
	header X-Robots-Tag "noindex, nofollow"
	header Referrer-Policy "strict-origin-when-cross-origin"
	header X-Content-Type-Options "nosniff"
	header X-Frame-Options "DENY"

	log {
		output stdout
		format console
	}
}
