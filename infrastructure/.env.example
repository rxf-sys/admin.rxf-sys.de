# ------------------------------------------------------------
# rxf-sys admin · backend configuration
# Copy to ./.env (next to docker-compose.yml) and fill in.
# ------------------------------------------------------------

APP_ENV=production
LOG_LEVEL=INFO
# JSON list. The admin SPA is served from the same origin, so this is mainly
# relevant if you ever expose the API to a different host.
CORS_ORIGINS=["https://admin.rxf-sys.de"]
AUTH_ENABLED=true

# ---- Cloudflare Access ----
# Team domain: <team>.cloudflareaccess.com (visible in Zero Trust dashboard).
CF_ACCESS_TEAM_DOMAIN=rxf-sys.cloudflareaccess.com
# AUD tag of the Access Application (Settings -> General -> Application Audience Tag).
CF_ACCESS_AUD=

# ---- Proxmox VE ----
# Create token at: Datacenter -> Permissions -> API Tokens
# Recommended: dedicated user `admin-dashboard@pve` with role `PVEAuditor`
# (read-only) + `VM.PowerMgmt` if you want the Restart button to work.
PROXMOX_HOST=192.168.2.200
PROXMOX_PORT=8006
PROXMOX_NODE=rxf-sys
PROXMOX_TOKEN_ID=admin-dashboard@pve!api
PROXMOX_TOKEN_SECRET=
PROXMOX_VERIFY_TLS=false

# ---- Proxmox Backup Server ----
# Same idea. Token needs `Datastore.Audit` on the datastore.
PBS_HOST=192.168.2.209
PBS_PORT=8007
PBS_TOKEN_ID=admin-dashboard@pbs!api
PBS_TOKEN_SECRET=
PBS_DATASTORE=backup
PBS_VERIFY_TLS=false

# ---- Cloudflare API ----
# Token scopes (minimum):
#   Account → Cloudflare Tunnel: Read
#   Zone → DNS: Read
#   Zone → SSL and Certificates: Read
CF_ACCOUNT_ID=66464b06aae97e8cdfce53397aa03d99
CF_ZONE_ID=
CF_ZONE_NAME=rxf-sys.de
CF_API_TOKEN=
CF_TUNNEL_ID=

# ---- UniFi (UCG-Ultra local API) ----
# PREFERRED (UniFi OS 4.x+): create an Integration API key in
#   Network -> Settings -> Control Plane -> Integrations -> Add API Key
# and put it in UNIFI_API_KEY. Leave UNIFI_USERNAME/PASSWORD empty.
#
# Fallback (older firmware): create a dedicated *Local* admin
#   (Settings -> Admins -> Create New Admin) with read-only role.
#   Cloud SSO accounts will not work.
UNIFI_HOST=192.168.2.1
UNIFI_PORT=443
UNIFI_API_KEY=
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_SITE=default
UNIFI_VERIFY_TLS=false

# ---- Probe targets (override defaults if needed) ----
# Format: PROBE_TARGETS={"vault":"http://192.168.2.203", ...}
# Leave unset to use the built-in defaults defined in app/config.py.

# ---- Cache TTLs (seconds) ----
CACHE_TTL_SYSTEM=15
CACHE_TTL_SERVICES=30
CACHE_TTL_TUNNEL=30
CACHE_TTL_PBS=60
CACHE_TTL_UNIFI=30
CACHE_TTL_CERTS=600
CACHE_TTL_GEOIP=21600

# ---- IP Geolocation (for ISP name) ----
# When the UniFi controller doesn't expose the ISP name (Integration API
# v10.x), the dashboard looks it up from the WAN IP via ipapi.co's free
# tier (1000 req/day, HTTPS, no auth). The IP is already public so no
# privacy regression. Set to false to disable.
GEOIP_ENABLED=true

# ---- Probe history (SQLite) ----
# Path inside the backend container where probe samples are persisted.
# The docker-compose mounts a named volume on /data, so the default works
# out of the box. Set to empty string to disable persistent history.
STORAGE_DB_PATH=/data/rxf-admin.db
HISTORY_RETENTION_DAYS=7
HISTORY_CLEANUP_INTERVAL_S=3600

# ---- Notifications (optional) ----
# Discord/Slack-compatible incoming webhook. Empty = disabled.
# Discord:  https://discord.com/api/webhooks/<id>/<token>
# Slack:    https://hooks.slack.com/services/<...>     (Discord-shape supported)
NOTIFY_WEBHOOK_URL=
# Service must stay degraded this many seconds before notifying (anti-flap).
NOTIFY_SERVICE_THRESHOLD_S=180
# Days before cert expiry that triggers a "expiring soon" notification.
NOTIFY_CERT_DAYS=14
# Background loop tick interval.
NOTIFY_INTERVAL_S=60
